# Portolan test scripts – environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# Base directory where the portolan-cli repo is checked out
BASE_DIR="/path/to/portolan"

# GCS buckets used by each E2E test
GCS_BUCKET_PORTOLAN="gs://your-portolan-catalog"
GCS_BUCKET_PORTOLAKE_SQLITE="gs://your-portolake-iceberg-sqlite"
GCS_BUCKET_PORTOLAKE_BIGLAKE="gs://your-portolake-iceberg-biglake"

# GCS bucket used by DuckDB / BigQuery query tests
GCS_BUCKET_QUERIES="gs://your-portolake-queries-bucket"

# STAC Browser base URL (for the public catalog link in the biglake test)
STAC_BROWSER_BASE_URL="https://your-user.github.io/iceberg-stac-browser"
